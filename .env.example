# ═══════════════════════════════════════════════════════════════
# ShopFlow — Environment Variables
# cp .env.example .env  →  fill in your values
# NEVER commit .env to Git
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars

# ── AWS RDS MySQL ─────────────────────────────────────────────────
# Find these in: AWS Console → RDS → your instance → Connectivity
DB_HOST=your-rds-instance.xxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=shopflow
DB_USER=shopflow_user
DB_PASSWORD=your-strong-db-password
DB_SSL=false                 # set to true for production RDS

# ── CORS ─────────────────────────────────────────────────────────
# Set to your EC2 public IP or domain in production
CORS_ORIGIN=*
